<?xml version="1.0" encoding="UTF-8"?>
<window>
    <!-- Custom favourites browser window for Kodi favouritesbrowser / MyFavourites.xml -->
    <defaultcontrol always="true">50</defaultcontrol>
    <views>50</views>
    <onload>SetFocus(50)</onload>

    <controls>

        <!-- Video/PVR pozadie ako na Home, ale bez celého background include -->
        <control type="videowindow">
            <visible>Player.HasVideo</visible>
            <depth>DepthBackground</depth>
            <include>FullScreenDimensions</include>
        </control>

        <!-- Jemné tmavé pozadie len pod obsahom, nie cez horný bar -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <aspectratio>stretch</aspectratio>
            <texture colordiffuse="E6000000">colors/white.png</texture>
        </control>

        <!-- HEADER: použije existujúci skin include info_header -->
        <include content="info_header">
            <param name="title" value="Obľúbené" />
            <param name="showicon" value="false" />
            <param name="show_pvr_running" value="false" />
            <param name="show_listinfo" value="false" />
        </include>

        <!-- HEADER: Počet položiek -->
        <control type="label">
            <top>28</top>
            <left>1180</left>
            <width>350</width>
            <height>30</height>
            <aligny>center</aligny>
            <font>light24</font>
            <textcolor>white</textcolor>
            <label>$LOCALIZE[31132]:$INFO[Container(50).CurrentItem][COLOR active] / [/COLOR]$INFO[Container(50).NumItems]</label>
        </control>

        <!-- LEFT: custom favourites list -->
        <control type="group">
            <include>openclose_fade_slight_left</include>

            <control type="fixedlist" id="50">
                <left>25</left>
                <top>105</top>
                <width>610</width>
                <height>930</height>
                <focusposition>3</focusposition>
                <movement>3</movement>
                <viewtype label="Favourites">list</viewtype>
                <orientation>vertical</orientation>
                <scrolltime tween="sine" easing="out">350</scrolltime>
                <pagecontrol>50001</pagecontrol>
                <onleft>50</onleft>
                <onright>50001</onright>
                <onup>50</onup>
                <ondown>50</ondown>

                <itemlayout width="590" height="118">
                    <control type="group">
                        <control type="image">
                            <left>0</left>
                            <top>6</top>
                            <width>590</width>
                            <height>106</height>
                            <aspectratio>stretch</aspectratio>
                            <texture colordiffuse="AA101414">colors/white.png</texture>
                            <bordertexture colordiffuse="55FFFFFF">colors/white.png</bordertexture>
                            <bordersize>1</bordersize>
                        </control>

                        <control type="image">
                            <left>15</left>
                            <top>21</top>
                            <width>120</width>
                            <height>70</height>
                            <aspectratio>keep</aspectratio>
                            <texture background="true" fallback="DefaultFolder.png">$INFO[ListItem.Icon]</texture>
                        </control>

                        <control type="label">
                            <left>165</left>
                            <top>0</top>
                            <width>390</width>
                            <height>118</height>
                            <aligny>center</aligny>
                            <font>light30</font>
                            <textcolor>white</textcolor>
                            <scroll>true</scroll>
                            <label>$INFO[ListItem.Label]</label>
                        </control>
                    </control>
                </itemlayout>

                <focusedlayout width="590" height="150">
                    <control type="group">
                        <animation type="Focus" condition="Skin.HasSetting(use_view_animations)" reversible="false">
                            <effect type="Zoom" start="97,97" end="100,100" center="295,75" time="220" tween="sine" easing="out" />
                        </animation>

                        <control type="image">
                            <left>0</left>
                            <top>5</top>
                            <width>590</width>
                            <height>140</height>
                            <aspectratio>stretch</aspectratio>
                            <texture colordiffuse="active">colors/white.png</texture>
                            <bordertexture colordiffuse="FFFFFFFF">colors/white.png</bordertexture>
                            <bordersize>1</bordersize>
                        </control>

                        <control type="image">
                            <left>18</left>
                            <top>30</top>
                            <width>155</width>
                            <height>90</height>
                            <aspectratio>keep</aspectratio>
                            <texture background="true" fallback="DefaultFolder.png">$INFO[ListItem.Icon]</texture>
                        </control>

                        <control type="label">
                            <left>205</left>
                            <top>0</top>
                            <width>345</width>
                            <height>150</height>
                            <aligny>center</aligny>
                            <font>regular36</font>
                            <textcolor>white</textcolor>
                            <scroll>true</scroll>
                            <label>$INFO[ListItem.Label]</label>
                        </control>
                    </control>
                </focusedlayout>
            </control>

            <include content="scrollbar">
                <param name="controlled_id" value="50" />
                <param name="onleft_id" value="50" />
                <param name="onright_id" value="50" />
                <param name="left" value="640" />
                <param name="top" value="105" />
                <param name="height" value="930" />
            </include>
        </control>

        <!-- RIGHT: clean preview panel using only available favourites info -->
        <control type="group">
            <include>openclose_fade_slight_right</include>

            <control type="image">
                <left>690</left>
                <top>105</top>
                <width>1205</width>
                <height>930</height>
                <aspectratio>stretch</aspectratio>
                <texture colordiffuse="BB141414">colors/white.png</texture>
                <bordertexture colordiffuse="66FFFFFF">colors/white.png</bordertexture>
                <bordersize>1</bordersize>
            </control>

            <!-- Veľká ikonka/thumb vybranej položky -->
            <control type="image">
                <left>691</left>
                <top>-20</top>
                <width>1203</width>
                <height>930</height>
                <aspectratio>keep</aspectratio>
                <texture background="true" fallback="DefaultFolder.png">$INFO[Container(50).ListItem.Icon]</texture>
            </control>

            <!-- Spodný informačný pás bez cesty a bez plotu -->
            <control type="image">
                <left>690</left>
                <top>782</top>
                <width>1205</width>
                <height>253</height>
                <aspectratio>stretch</aspectratio>
                <texture colordiffuse="DD080808">colors/white.png</texture>
                <bordertexture colordiffuse="44FFFFFF">colors/white.png</bordertexture>
                <bordersize>1</bordersize>
            </control>

            <control type="label">
                <left>735</left>
                <top>825</top>
                <width>1115</width>
                <height>62</height>
                <align>center</align>
                <aligny>center</aligny>
                <font>regular42</font>
                <textcolor>active</textcolor>
                <scroll>true</scroll>
                <label>$INFO[Container(50).ListItem.Label]</label>
            </control>
        </control>

        <!-- Empty state -->
        <control type="label">
            <visible>Integer.IsEqual(Container(50).NumItems,0)</visible>
            <left>690</left>
            <top>470</top>
            <width>1205</width>
            <height>90</height>
            <align>center</align>
            <aligny>center</aligny>
            <font>regular36</font>
            <textcolor>grey</textcolor>
            <label>Žiadne obľúbené položky</label>
        </control>
    </controls>
</window>
